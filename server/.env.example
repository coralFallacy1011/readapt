MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/readapt?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
PORT=5000
CLIENT_URL=https://your-frontend.vercel.app
REDIS_URL=redis://localhost:6379

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=readapt-storage

# Optional: For S3-compatible services (MinIO, DigitalOcean Spaces, etc.)
# S3_ENDPOINT=https://your-endpoint.com

# Google Cloud ML Services Configuration
# Path to Google Cloud service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
